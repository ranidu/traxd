{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "tsc-check": {
      "dependsOn": ["^tsc-check"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
